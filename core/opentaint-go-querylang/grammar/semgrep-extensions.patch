+@parser::members {
+    // Semgrep: enable the `operand` (composite-literal) alternative for a qualified
+    // type literal `pkg.T{...}`. Without imports the base predicate routes `pkg.T`
+    // to `methodExpr`, which cannot carry a `{...}` literal value. We only widen the
+    // gate; ANTLR still picks `methodExpr`/`operandName` contextually elsewhere.
+    @Override
+    public boolean isOperand() {
+        org.antlr.v4.runtime.BufferedTokenStream stream = (org.antlr.v4.runtime.BufferedTokenStream) _input;
+        if (stream.LT(1).getType() == GoParser.IDENTIFIER
+                && stream.LT(2).getType() == GoParser.DOT
+                && (stream.LT(3).getType() == GoParser.IDENTIFIER || stream.LT(3).getType() == GoParser.METAVAR_IDENT)
+                && stream.LT(4).getType() == GoParser.L_CURLY) {
+            return true;
+        }
+        return super.isOperand();
+    }
+}

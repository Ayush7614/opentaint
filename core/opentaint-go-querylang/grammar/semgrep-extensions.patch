+    ;
+
+semgrepTopItem
+    : packageClause
+    | importDecl
+    | functionDecl
+    | methodDecl
+    | declaration
+    | statement
+    | compositeLit
+    | ELLIPSIS
+    ;
+
+semgrepStmtList
+    : statement (eos statement)* eos?
+    ;
